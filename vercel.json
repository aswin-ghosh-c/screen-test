{
  "version": 2,
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/client/assets/$1"
    },
    {
      "source": "/robots.txt",
      "destination": "/client/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/client/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
